{
  "extends": "./configs/typescript/tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "configs/testing/**/*.ts",
    "configs/testing/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
