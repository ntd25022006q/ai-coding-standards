# =============================================================================
# AI Coding Standards - .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
.next/
out/
build/
dist/

# Testing
coverage/
.nyc_output/

# Environment variables (NEVER commit real secrets)
.env
.env*.local
.env.production
.env.staging

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Prisma
prisma/migrations/migration_lock.toml

# OS files
.DS_Store
Thumbs.db
*.pem

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Backup files created by setup script
*.bak
