#!/bin/bash
# ============================================
# 🔒 PRE-COMMIT HOOK v2.0.0
# ============================================
# Portable: works with rg AND grep fallback
# Runs on EVERY git commit - cannot be bypassed safely
# ============================================

# Prevent running outside of a git repository
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$PROJECT_ROOT" ]; then
  echo "❌ This script must be run from within a git repository."
  exit 1
fi
cd "$PROJECT_ROOT" || exit 1

echo -e "\033[0;34m🔒 Pre-commit quality checks...\033[0m"
echo ""

# ============================================
# Step 1: Get staged TypeScript/JavaScript files
# ============================================
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|mjs)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "✓ No TypeScript/JavaScript files staged. Skipping checks."
  exit 0
fi

STAGED_COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')
echo "📝 ${STAGED_COUNT} file(s) staged:"
echo "$STAGED_FILES" | head -10
if [ "$STAGED_COUNT" -gt 10 ]; then
  echo "   ... and $((STAGED_COUNT - 10)) more"
fi
echo ""

HAS_ERRORS=false

# ============================================
# Step 2: TypeScript compilation check
# ============================================
echo -e "\033[1;33m[1/4] TypeScript check...\033[0m"

if command -v npx &>/dev/null && [ -f "tsconfig.json" ]; then
  if ! npx tsc --noEmit 2>&1; then
    echo ""
    echo -e "\033[0;31m❌ TypeScript errors found. Fix before committing.\033[0m"
    echo "   Run: npx tsc --noEmit"
    HAS_ERRORS=true
  else
    echo -e "\033[0;32m  ✓ TypeScript: 0 errors\033[0m"
  fi
else
  echo -e "\033[1;33m  ⚠ Skipped (tsc not available)\033[0m"
fi

# ============================================
# Step 3: ESLint on staged files
# ============================================
echo -e "\033[1;33m[2/4] ESLint check on staged files...\033[0m"

ESLINT_CMD=""
if [ -f "eslint.config.mjs" ] || [ -f "eslint.config.js" ] || [ -f ".eslintrc.json" ]; then
  if command -v npx &>/dev/null; then
    # Build file list argument safely
    FILES_ARG=""
    while IFS= read -r file; do
      if [ -f "$file" ]; then
        FILES_ARG="$FILES_ARG \"$file\""
      fi
    done <<< "$STAGED_FILES"

    if [ -n "$FILES_ARG" ]; then
      # Use eval to properly handle quoted filenames with spaces
      ESLINT_OUTPUT=$(eval "npx eslint --no-warn-ignored $FILES_ARG --max-warnings=0" 2>&1)
      ESLINT_EXIT=$?
      # Handle missing dependencies gracefully
      if echo "$ESLINT_OUTPUT" | grep -q "Cannot find module\|ERR_MODULE_NOT_FOUND\|Cannot find package"; then
        echo -e "\033[1;33m  ⚠ ESLint deps not installed - skipping (install: npm i -D eslint typescript-eslint @eslint/js)\033[0m"
      elif [ $ESLINT_EXIT -ne 0 ]; then
        echo -e "\033[0;31m❌ ESLint errors found. Fix before committing.\033[0m"
        echo "   Run: npx eslint . --fix"
        HAS_ERRORS=true
      else
        echo -e "\033[0;32m  ✓ ESLint: 0 errors\033[0m"
      fi
    fi
  else
    echo -e "\033[1;33m  ⚠ Skipped (npx not available)\033[0m"
  fi
else
  echo -e "\033[1;33m  ⚠ Skipped (no ESLint config found)\033[0m"
fi

# ============================================
# Step 4: Forbidden patterns in staged files
# ============================================
echo -e "\033[1;33m[3/4] Forbidden patterns check...\033[0m"

FORBIDDEN="as any|: any|@ts-ignore|@ts-expect-error"
FOUND_FORBIDDEN=false

while IFS= read -r file; do
  if [ -f "$file" ]; then
    # Use basic grep - always available
    MATCHES=$(grep -nE "$FORBIDDEN" "$file" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
      echo -e "\033[0;31m  ✗ Forbidden pattern in $file:\033[0m"
      echo "$MATCHES" | head -5 | while read -r line; do
        echo "      $line"
      done
      FOUND_FORBIDDEN=true
    fi
  fi
done <<< "$STAGED_FILES"

if [ "$FOUND_FORBIDDEN" = true ]; then
  echo ""
  echo -e "\033[0;31m❌ Forbidden patterns found. Remove before committing.\033[0m"
  HAS_ERRORS=true
else
  echo -e "\033[0;32m  ✓ No forbidden patterns\033[0m"
fi

# ============================================
# Step 5: Console.log check (warning only)
# ============================================
echo -e "\033[1;33m[4/4] Console.log check...\033[0m"

FOUND_CONSOLE=false
while IFS= read -r file; do
  if [ -f "$file" ]; then
    MATCHES=$(grep -n "console\.log" "$file" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
      echo -e "\033[1;33m  ⚠ console.log in $file:\033[0m"
      echo "$MATCHES" | head -3 | while read -r line; do
        echo "      $line"
      done
      FOUND_CONSOLE=true
    fi
  fi
done <<< "$STAGED_FILES"

if [ "$FOUND_CONSOLE" = true ]; then
  echo -e "\033[1;33m  Warning: Use structured logger instead of console.log\033[0m"
else
  echo -e "\033[0;32m  ✓ No console.log found\033[0m"
fi

# ============================================
# FINAL DECISION
# ============================================
echo ""

if [ "$HAS_ERRORS" = true ]; then
  echo -e "\033[0;31m❌ Pre-commit checks FAILED. Commit blocked.\033[0m"
  echo -e "\033[0;31m   Fix the errors above and try again.\033[0m"
  echo -e "\033[0;31m   To bypass (NOT recommended): git commit --no-verify\033[0m"
  exit 1
else
  echo -e "\033[0;32m✅ Pre-commit checks PASSED! Safe to commit.\033[0m"
  exit 0
fi
