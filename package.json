{
  "name": "ai-agent-coding-standards",
  "version": "2.3.0",
  "private": false,
  "description": "6 layers of defense forcing every AI agent to write production-ready code — clone once, deploy standards everywhere",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath hooks",
    "setup": "bash scripts/setup.sh .",
    "validate": "bash scripts/validate.sh",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "echo 'Build skipped: this is a template repository'",
    "check:all": "npm run typecheck && npm run lint && npm run test && npm run validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.22.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
