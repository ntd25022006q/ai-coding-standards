{
  "name": "ai-agent-coding-standards",
  "version": "2.3.0",
  "private": false,
  "description": "Enforce production-grade code quality across AI coding agents — rule files, strict configs, and a 10-point validation suite",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath hooks",
    "setup": "tsx scripts/setup.ts .",
    "validate": "tsx scripts/validate.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc --noEmit && echo '✓ TypeScript compilation successful'",
    "check:all": "npm run typecheck && npm run lint && npm run test && npm run format:check && npm run validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
