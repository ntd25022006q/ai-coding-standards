# =============================================================================
# AI Coding Standards - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file or real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# MCP Server: GitHub Integration
# Required for the GitHub MCP server to interact with repositories.
# Generate at: https://github.com/settings/tokens
# Scopes needed: repo, read:org
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# MCP Server: Brave Search
# Required for the Brave Search MCP server to perform web searches.
# Obtain at: https://brave.com/search/api/
# -----------------------------------------------------------------------------
BRAVE_API_KEY=

# -----------------------------------------------------------------------------
# MCP Server: Tavily Search (optional)
# Alternative search API for the Tavily MCP server.
# Obtain at: https://tavily.com/
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
